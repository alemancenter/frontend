# =============================================================================
# Frontend Production Environment — alemedu.com
# =============================================================================
# 1. Copy this file to .env.production  (same directory)
# 2. Fill in the real values
# 3. IMPORTANT: set NEXT_PUBLIC_* vars in the shell BEFORE running npm run build
#    export NEXT_PUBLIC_API_URL=https://api.alemedu.com/api
#    export NEXT_PUBLIC_FRONTEND_API_KEY=<your-key>
#    npm run build
# =============================================================================

# ── Public (compiled into browser bundle at build time) ─────────────────────
# Backend public URL — used by the browser for all API calls
NEXT_PUBLIC_API_URL=https://api.alemedu.com/api

# Frontend application URL
NEXT_PUBLIC_APP_URL=https://alemedu.com

# Default country (Jordan = 1)
NEXT_PUBLIC_DEFAULT_COUNTRY_ID=1

# Must match FRONTEND_API_KEY in the backend .env
# ⚠ MUST be set in the shell before `npm run build` for browser requests to work
NEXT_PUBLIC_FRONTEND_API_KEY=REPLACE_WITH_STRONG_RANDOM_KEY

# ── Server-only (read at SSR request time — never sent to browser) ───────────
# Direct HTTP to Go Fiber, bypasses Nginx and SSL overhead
API_INTERNAL_URL=http://127.0.0.1:8081/api

# Host header for SSR requests so Fiber/Nginx routes correctly
API_HOSTNAME=api.alemedu.com

# Server-only version of the frontend key (same value, never exposed)
FRONTEND_API_KEY=REPLACE_WITH_STRONG_RANDOM_KEY
